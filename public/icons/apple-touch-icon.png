<svg width="180" height="180" viewBox="0 0 180 180" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background gradient circle -->
  <defs>
    <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0EA5E9;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#8B5CF6;stop-opacity:1" />
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Main circle -->
  <circle cx="90" cy="90" r="85" fill="url(#logoGradient)" filter="url(#glow)"/>
  
  <!-- Letter M -->
  <text x="90" y="115" text-anchor="middle" fill="white" font-size="80" font-weight="bold" font-family="Arial, sans-serif">M</text>
  
  <!-- Outer ring -->
  <circle cx="90" cy="90" r="83" fill="none" stroke="white" stroke-width="2" opacity="0.3"/>
</svg>
